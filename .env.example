# TraderMate Data Sync Daemon Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-secure-mysql-password-here
MYSQL_DATABASE=tradermate

# vn.py database settings (optional, will fall back to MYSQL_* values)
# Set these if you want vn.py to use a different DB or credentials
VN_DATABASE_NAME=mysql
VN_DATABASE_HOST=127.0.0.1
VN_DATABASE_PORT=3306
VN_DATABASE_USER=root
VN_DATABASE_PASSWORD=your-secure-vn-db-password-here
VN_DATABASE_DB=tradermate

# JWT Configuration
# Generate a secure secret key (minimum 32 chars): openssl rand -hex 32
SECRET_KEY=your-jwt-secret-key-here

# Admin Account Configuration
# In production, ADMIN_PASSWORD must be set. In development, if not set a secure random password will be generated and logged on startup.
ADMIN_PASSWORD=your-secure-admin-password-here
ADMIN_EMAIL=admin@tradermate.local

# Tushare API Configuration
# Get your token from https://tushare.pro/
TUSHARE_TOKEN=your-tushare-token-here

# Sync Configuration
SYNC_INTERVAL_HOURS=24
BATCH_SIZE=100
MAX_RETRIES=3

# CORS Configuration (optional, defaults to ["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"])
# Format: JSON array string, e.g. CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# Logging Configuration
LOG_LEVEL=INFO