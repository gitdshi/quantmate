# QuantMate Data Sync Daemon Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-secure-mysql-password-here

# JWT Configuration
# Generate a secure secret key (minimum 32 chars): openssl rand -hex 32
SECRET_KEY=your-jwt-secret-key-here

# Admin Account Configuration
# In production, ADMIN_PASSWORD must be set. In development, if not set a secure random password will be generated and logged on startup.
ADMIN_PASSWORD=your-secure-admin-password-here
ADMIN_EMAIL=admin@quantmate.local

# Tushare API Configuration
# Get your token from https://tushare.pro/
TUSHARE_TOKEN=your-tushare-token-here

# Sync Configuration
SYNC_INTERVAL_HOURS=24
BATCH_SIZE=100
MAX_RETRIES=3

# DataSync initialization coverage window.
# The runtime uses the environment-specific value below by default, falling back to
# DATASYNC_INIT_LOOKBACK_DAYS when set globally.
# Defaults: dev=365, staging=3650, prod=7300.
DATASYNC_INIT_LOOKBACK_DAYS=
DATASYNC_INIT_LOOKBACK_DEV_DAYS=365
DATASYNC_INIT_LOOKBACK_STAGING_DAYS=3650
DATASYNC_INIT_LOOKBACK_PROD_DAYS=7300

# Daily daemon schedule.
SYNC_HOUR=2
SYNC_MINUTE=0

# Backfill worker configuration: number of threads used for backfill dispatch/execution.
# Main thread dispatches tasks and performs status writes; child threads execute interface syncs.
# Default: 10
BACKFILL_WORKERS=10

# Dedicated backfill loop idle interval after the queue is drained.
BACKFILL_IDLE_INTERVAL_HOURS=4

# When another backfill owner is holding the DB lock, retry after this many seconds.
BACKFILL_LOCK_RETRY_SECONDS=60

# Optional per-source backfill concurrency overrides.
# If unset, backfill falls back to the regular source concurrency limit for that provider.
BACKFILL_TUSHARE_CONCURRENCY=3
# Example: BACKFILL_AKSHARE_CONCURRENCY=4

# Optional manual one-shot backfill limit for debugging.
# Leave empty in normal operation so the dedicated backfill loop scans all retryable rows.
BACKFILL_LOOKBACK_DAYS=

# CORS Configuration (optional, defaults to ["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"])
# Format: JSON array string, e.g. CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]'

# Logging Configuration
LOG_LEVEL=INFO
QUANTMATE_LOG_FORMAT=text

# Application runtime overrides
APP_ENV=development
ADMIN_USERNAME=admin
API_HOST=0.0.0.0
API_PORT=8000
APP_BUILD_TIME=dev

# DataSync runtime tuning
DATASYNC_TIMEZONE=Asia/Shanghai
DRY_RUN=false
SYNC_PARALLEL_WORKERS=4
LOOKBACK_DAYS=60
BACKFILL_INTERVAL_HOURS=4
BACKFILL_DAYS=30
BACKFILL_LOCK_STALE_HOURS=6
SYNC_STATUS_RUNNING_STALE_HOURS=6
SYNC_INIT_DEFAULT_START_DATE=2000-01-01
SYNC_INIT_BATCH_SIZE=200
DATASYNC_SKIP_INITIAL_DAILY=false
DATASYNC_SKIP_INITIAL_RECONCILE=false
TUSHARE_CONCURRENCY=3

# Job and queue timeouts
MANUAL_DATASYNC_JOB_TIMEOUT_SECONDS=1800
DATASYNC_BACKFILL_JOB_TIMEOUT_SECONDS=3600
BACKTEST_JOB_TIMEOUT_SECONDS=3600
BACKTEST_BULK_JOB_TIMEOUT_SECONDS=7200
BACKTEST_OPTIMIZATION_JOB_TIMEOUT_SECONDS=14400
BACKTEST_RESULT_TTL_SECONDS=604800
OPTIMIZATION_TASK_JOB_TIMEOUT_SECONDS=14400
OPTIMIZATION_TASK_RESULT_TTL_SECONDS=259200
JOB_STORAGE_TTL_SECONDS=604800

# Worker queue defaults
QUEUE_HIGH_DEFAULT_TIMEOUT_SECONDS=600
QUEUE_DEFAULT_DEFAULT_TIMEOUT_SECONDS=1800
QUEUE_LOW_DEFAULT_TIMEOUT_SECONDS=3600
QUEUE_BACKTEST_DEFAULT_TIMEOUT_SECONDS=3600
QUEUE_OPTIMIZATION_DEFAULT_TIMEOUT_SECONDS=7200
QUEUE_RDAGENT_DEFAULT_TIMEOUT_SECONDS=14400
WORKER_DEFAULT_QUEUE_NAMES=["backtest","optimization","default","low"]
CLI_REDIS_SOCKET_TIMEOUT_SECONDS=5.0

# Backtest and optimization defaults
BACKTEST_DEFAULT_CAPITAL=100000.0
BACKTEST_DEFAULT_RATE=0.0001
BACKTEST_DEFAULT_SLIPPAGE=0.0
BACKTEST_DEFAULT_SIZE=1
BACKTEST_DEFAULT_PRICETICK=0.01
BACKTEST_DEFAULT_BENCHMARK=399300.SZ
OPTIMIZATION_DEFAULT_RATE=0.0003
OPTIMIZATION_DEFAULT_SLIPPAGE=0.0001
OPTIMIZATION_MAX_WORKERS=4
TRADING_DEFAULT_SLIPPAGE=0.001

# Market data and quote runtime overrides
AKSHARE_CALLS_PER_MIN=20
# Optional per-endpoint AkShare rate overrides, for example: AKSHARE_RATE_index_stock_cons=20
AKSHARE_MAX_RETRIES=3
AKSHARE_BACKOFF_BASE_SECONDS=5
REALTIME_QUOTE_BULK_CACHE_TTL_SECONDS=10
REALTIME_QUOTE_AKSHARE_TIMEOUT_SECONDS=8.0
REALTIME_QUOTE_TENCENT_TIMEOUT_SECONDS=3.0
REALTIME_QUOTE_TENCENT_RETRIES=2
REALTIME_QUOTE_TENCENT_BACKOFF_SECONDS=0.4
QLIB_DATA_DIR=

# Optional one-off ingest CLI flags
INGEST_STOCK_BASIC=false
INGEST_ALL_DAILY=false
SAMPLE_TS=

# RD-Agent runtime overrides
RDAGENT_SIDECAR_URL=http://rdagent-service:8001
RDAGENT_REQUEST_TIMEOUT_SECONDS=14400
RDAGENT_WORKSPACE=/tmp/rdagent_workspace
RDAGENT_SERVICE_PORT=8001
