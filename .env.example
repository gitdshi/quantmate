# QuantMate Data Sync Daemon Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-secure-mysql-password-here

# JWT Configuration
# Generate a secure secret key (minimum 32 chars): openssl rand -hex 32
SECRET_KEY=your-jwt-secret-key-here

# Admin Account Configuration
# In production, ADMIN_PASSWORD must be set. In development, if not set a secure random password will be generated and logged on startup.
ADMIN_PASSWORD=your-secure-admin-password-here
ADMIN_EMAIL=admin@quantmate.local

# Tushare API Configuration
# Get your token from https://tushare.pro/
TUSHARE_TOKEN=your-tushare-token-here

# DataSync time window.
# If SYNC_INIT_DEFAULT_START_DATE is set and non-empty, that date is used.
# If it is empty, the environment floor is used: dev=1 year ago, staging=10 years ago, prod=20 years ago.
# This same window is used by datasync, init and backfill.
SYNC_INIT_DEFAULT_START_DATE=

# CORS Configuration (optional, defaults to ["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"])
# Format: JSON array string, e.g. CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]'

# Logging Configuration (startup/deployment)
LOG_LEVEL=INFO
QUANTMATE_LOG_FORMAT=text

# Application startup overrides
APP_ENV=development
ADMIN_USERNAME=admin
API_HOST=0.0.0.0
API_PORT=8000
APP_BUILD_TIME=dev

# Deployment image tags used by docker-compose.staging.yml.
# Both tags are intentionally left blank so staging/prod fail fast instead of
# silently falling back to latest when a deploy tag is missing.
GITHUB_OWNER=gitdshi
IMAGE_TAG=
PORTAL_IMAGE_TAG=

# Startup-only DataSync flags
DRY_RUN=false
DATASYNC_SKIP_INITIAL_DAILY=false
DATASYNC_SKIP_INITIAL_RECONCILE=false

# Runtime behavior variables are DB-managed.
# Use Settings -> System Management -> System Configuration to adjust sync, worker,
# backtest, market cache, and timeout behavior without editing .env.

QLIB_DATA_DIR=

# Optional one-off ingest CLI flags
INGEST_STOCK_BASIC=false
INGEST_ALL_DAILY=false
SAMPLE_TS=

# RD-Agent startup overrides
RDAGENT_SIDECAR_URL=http://rdagent-service:8001
RDAGENT_WORKSPACE=/tmp/rdagent_workspace
RDAGENT_SERVICE_PORT=8001
